<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>com.rtosta.zapzap</id>
  <launchable type="desktop-id">com.rtosta.zapzap.desktop</launchable>

  <name>ZapZap</name>
  <summary>Message with WhatsApp Web</summary>

  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>

  <developer id="com.rtosta">
    <name>Rafael Tosta</name>
  </developer>

  <url type="homepage">https://rtosta.com/zapzap/</url>
  <url type="bugtracker">https://github.com/rafatosta/zapzap/issues</url>
  <url type="vcs-browser">https://github.com/rafatosta/zapzap</url>
  <url type="donation">https://rtosta.com/zapzap/#donate</url>

  <branding>
    <color type="primary" scheme_preference="light">#f7f5f3</color>
    <color type="primary" scheme_preference="dark">#1d1f1f</color>
  </branding>

  <categories>
    <category>Chat</category>
    <category>InstantMessaging</category>
    <category>Network</category>
  </categories>

  <description>
    <p>
      ZapZap provides a dedicated desktop window for WhatsApp Web on Linux,
      with system tray integration, notifications, and support for multiple
      accounts.
    </p>
    <p>
      It is designed for users who want quick access to their conversations
      without keeping a browser tab open.
    </p>
  </description>

