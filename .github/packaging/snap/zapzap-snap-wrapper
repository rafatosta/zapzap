#!/bin/sh

set -eu

# snapd gives confined desktop applications a snap-specific XDG_RUNTIME_DIR
# (for example /run/user/1000/snap.zapzap). PulseAudio and pipewire-pulse
# keep their native socket in the parent runtime directory, so libpulse clients
# may fail to discover audio automatically on core24. Point them at the host
# user socket when it exists while preserving an explicit user/server setting.
if [ -z "${PULSE_SERVER:-}" ] && [ -n "${XDG_RUNTIME_DIR:-}" ]; then
    pulse_socket="${XDG_RUNTIME_DIR%/}/../pulse/native"
    if [ -S "${pulse_socket}" ]; then
        export PULSE_SERVER="unix:${pulse_socket}"
    fi
fi

exec "$SNAP/usr/bin/zapzap" "$@"
